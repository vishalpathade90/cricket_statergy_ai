{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "env": {
    "GROQ_API_KEY": "@groq_api_key"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 30,
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api/index.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist",
      "methods": ["GET"]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
